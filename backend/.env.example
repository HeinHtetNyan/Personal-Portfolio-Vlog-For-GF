# ── Database ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://july:july_password@localhost:5432/july_portfolio

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Or run: python setup.py
SECRET_KEY=replace-with-output-of-setup.py
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── File uploads ─────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── First admin (one-time setup) ─────────────────────────────
# Used only on first startup to seed the admin account.
# After setup, change your password via the admin dashboard.
# Or run: python setup.py
FIRST_ADMIN_EMAIL=you@yourdomain.com
FIRST_ADMIN_PASSWORD=choose-a-strong-password
